#!/usr/bin/env bash
set -euo pipefail

APP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$APP_ROOT"

echo "== Tests =="
bin/rails test

echo
echo "== API Spec =="
bin/check-api-spec

echo
echo "== RuboCop =="
bin/rubocop

echo
echo "== Brakeman =="
bin/brakeman --quiet --no-pager --exit-on-warn --exit-on-error
